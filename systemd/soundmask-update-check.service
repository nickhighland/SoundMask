[Unit]
Description=SoundMask update check
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=soundmask
Group=soundmask
WorkingDirectory=/opt/SoundMask
EnvironmentFile=-/etc/soundmask/soundmask.env
ExecStart=/opt/SoundMask/.venv/bin/python -m app.update_manager check
StandardOutput=append:/var/lib/soundmask/logs/updates.log
StandardError=append:/var/lib/soundmask/logs/updates.log
